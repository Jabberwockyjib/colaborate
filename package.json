{
  "name": "colaborate",
  "version": "0.0.0",
  "private": true,
  "description": "Client feedback overlay with MCP-driven fix loop. Forked from NeosiaNexus/SitePing.",
  "homepage": "https://github.com/develotype/colaborate",
  "type": "module",
  "author": "Develotype <bdoud@develotype.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/develotype/colaborate.git"
  },
  "bugs": {
    "url": "https://github.com/develotype/colaborate/issues"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "clean": "turbo run clean",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest",
    "test:run": "NODE_OPTIONS=--no-experimental-webstorage vitest run",
    "test:e2e": "NODE_OPTIONS=--no-experimental-webstorage playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@playwright/test": "^1.59.1",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "jsdom": "29.1.0",
    "tsup": "^8.5.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
