{
  "name": "@colaborate/adapter-prisma",
  "version": "0.0.0",
  "description": "Prisma adapter for Colaborate — server-side request handlers",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node ../../scripts/fix-dts.mjs dist",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "colaborate",
    "prisma",
    "adapter",
    "feedback",
    "api-handler",
    "nextjs",
    "feedback-api",
    "self-hosted",
    "typescript"
  ],
  "author": "Develotype <bdoud@develotype.com>",
  "license": "MIT",
  "homepage": "https://github.com/develotype/colaborate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/develotype/colaborate.git",
    "directory": "packages/adapter-prisma"
  },
  "bugs": {
    "url": "https://github.com/develotype/colaborate/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@colaborate/adapter-memory": "workspace:*",
    "@colaborate/core": "workspace:*",
    "@colaborate/triage": "workspace:*",
    "@types/node": "^25.5.0"
  },
  "peerDependencies": {
    "@colaborate/core": "workspace:*",
    "@colaborate/triage": "workspace:*",
    "@prisma/client": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "@colaborate/triage": {
      "optional": true
    }
  }
}
